<Window x:Class="TravelMate.AddRouteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj nowy dojazd"
        Height="749"
        Width="611"
        WindowStartupLocation="CenterOwner"
        Background="#f8fafc">

 
    <Window.Resources>

        
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>

        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

    </Window.Resources>

    
    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Border Background="White"
                CornerRadius="12"
                Padding="20"
                Margin="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                
                <TextBlock Text="Adres startowy" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtFromAddressFull" IsReadOnly="True"/>
                <Button Content="Ustaw punkt startowy na mapie"
                        Width="240"
                        Click="BtnSetStartPoint_Click"
                        Style="{StaticResource SecondaryButton}"/>

              
                <TextBlock Text="Adres końcowy" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtToAddressFull" IsReadOnly="True"/>
                <Button Content="Ustaw punkt końcowy na mapie"
                        Width="240"
                        Click="BtnSetEndPoint_Click"
                        Style="{StaticResource SecondaryButton}"/>

                
                <TextBlock Text="Środek transportu" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="cmbTransport">
                    <ComboBoxItem Content="Samochód"/>
                    <ComboBoxItem Content="Autobus"/>
                    <ComboBoxItem Content="Pociąg"/>
                    <ComboBoxItem Content="Samolot"/>
                    <ComboBoxItem Content="Statek"/>
                    <ComboBoxItem Content="Inny"/>
                </ComboBox>

                <TextBlock Text="Przewoźnik" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtCarrier"/>

                <TextBlock Text="Numer rejsu / lotu / pociągu" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtRouteNumber"/>

                
                <TextBlock Text="Data wyjazdu" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="dpDeparture"/>

                <TextBlock Text="Godzina wyjazdu (HH:MM)" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtDepartureTime" 
         Width="120"
         Text="00:00"
         PreviewTextInput="txtTime_PreviewTextInput"
         PreviewKeyDown="txtTime_PreviewKeyDown"
         GotFocus="txtTime_GotFocus"
         TextAlignment="Center"/>

                
                <TextBlock Text="Data przyjazdu" Style="{StaticResource LabelStyle}"/>
                <DatePicker x:Name="dpArrival"/>

                <TextBlock Text="Godzina przyjazdu (HH:MM)" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtArrivalTime" 
         Width="120"
         Text="00:00"
         PreviewTextInput="txtTime_PreviewTextInput"
         PreviewKeyDown="txtTime_PreviewKeyDown"
         GotFocus="txtTime_GotFocus"
         TextAlignment="Center"/>
                
                <TextBlock Text="Cena" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtPrice" 
         Width="120"
         Text="0.00"
         PreviewTextInput="txtPrice_PreviewTextInput"
         PreviewKeyDown="txtPrice_PreviewKeyDown"
         GotFocus="txtPrice_GotFocus"
         TextAlignment="Center"/>

                <TextBlock Text="Waluta" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="cmbCurrency" Width="120">
                    <ComboBoxItem Content="PLN" IsSelected="True"/>
                    <ComboBoxItem Content="EUR"/>
                    <ComboBoxItem Content="USD"/>
                    
                </ComboBox>

               
                <TextBlock Text="Uwagi" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="txtNotes"
                         AcceptsReturn="True"
                         Height="70"
                         TextWrapping="Wrap"/>

                
                <Button Content="Zapisz dojazd"
                        Width="180"
                        HorizontalAlignment="Center"
                        Click="BtnSaveRoute_Click"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,25,0,0"/>

            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
