<Window x:Class="TravelMate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rejestracja" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#FFFAFAFA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Rejestracja" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock Text="Login" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLogin" Height="30" FontSize="14"
                     Padding="5" BorderBrush="#FFCCCCCC" BorderThickness="1"
                     Background="White"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="Hasło" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtHaslo" Height="30" FontSize="14"
                         Padding="5" BorderBrush="#FFCCCCCC" BorderThickness="1"
                         Background="White"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock Text="Email" Margin="0,0,0,5"/>
            <TextBox x:Name="txtEmail" Height="30" FontSize="14"
                     Padding="5" BorderBrush="#FFCCCCCC" BorderThickness="1"
                     Background="White"/>
        </StackPanel>

        <Button Grid.Row="4" Content="Zarejestruj się" Height="40" FontSize="16"
                Margin="0,20,0,0" Background="#FF2196F3" Foreground="White"
                BorderThickness="0" Cursor="Hand"
                HorizontalAlignment="Stretch" VerticalAlignment="Top"
                Click="Register_Click"/>
        <Button Content="Masz już konto? Zaloguj się" Height="30" Margin="0,79,0,50"
        Background="Transparent" Foreground="#FF2196F3" BorderThickness="0" 
        Cursor="Hand" Click="GoToLogin_Click" RenderTransformOrigin="0.463,10.998" Grid.Row="4"/>

    </Grid>
</Window>
