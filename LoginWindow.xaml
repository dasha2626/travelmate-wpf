<Window x:Class="TravelMate.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#FFFAFAFA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Logowanie" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock Text="Login" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLogin" Height="30" FontSize="14"
                     Padding="5" BorderBrush="#FFCCCCCC" BorderThickness="1"
                     Background="White"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="Hasło" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtHaslo" Height="30" FontSize="14"
                         Padding="5" BorderBrush="#FFCCCCCC" BorderThickness="1"
                         Background="White"/>
        </StackPanel>

        <Button Grid.Row="3" Content="Zaloguj się" Height="40" FontSize="16"
                Margin="0,20,0,0" Background="#FF2196F3" Foreground="White"
                BorderThickness="0" Cursor="Hand"
                HorizontalAlignment="Stretch" VerticalAlignment="Top"
                Click="Login_Click"/>
        <Button Content="Wróć do rejestracji" Height="30" Margin="10,80,-10,10"
             Background="Transparent" Foreground="#FF2196F3" BorderThickness="0"
              Cursor="Hand" Click="GoToRegister_Click" Grid.Row="3"/>

    </Grid>
</Window>

