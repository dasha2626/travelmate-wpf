<Window x:Class="TravelMate.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Szczegóły wycieczki" Height="700" Width="900">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10" Background="#F9F9F9">


            <Border BorderBrush="Black" BorderThickness="2" CornerRadius="5" Padding="10" Margin="0,0,0,10" Background="#FFF8F0">
                <StackPanel>
                    <TextBlock Text="{Binding Path=Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                               FontSize="20" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="📊 STATYSTYKI PODRÓŻY" FontWeight="Bold" Margin="0,0,0,5"/>


                    <TextBlock Margin="0,2">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="💰 Koszt całkowity: {0:N0} PLN    ✈️ Etapy dojazdów: {1}    🛏️ Noclegi: {2}">
                                <Binding Path="KosztCalkowity"/>
                                <Binding Path="EtapyDojazdow"/>
                                <Binding Path="LiczbaNoclegow"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🗓️ Czas trwania: {0} dni    ⭐ Ocena: {1}    🗺️ Punkty: {2}">
                                <Binding Path="CzasTrwaniaDni"/>
                                <Binding Path="OcenaGwiazdkowa"/>
                                <Binding Path="LiczbaPunktow"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>


                    <TextBlock Text="DOJAZDY (transport)" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBlock Margin="0,2">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="💸 Najtańszy: {0:N0} PLN    💸 Najdroższy: {1:N0} PLN">
                                <Binding Path="DojazdyMin"/>
                                <Binding Path="DojazdyMax"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🚆 Śr. cena transportu: {0:N0} PLN    🚗 Łączny koszt dojazdów: {1:N0} PLN">
                                <Binding Path="DojazdyAvg"/>
                                <Binding Path="DojazdySum"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="📍 Najdłuższy etap: {0:N0} km    📍 Najkrótszy: {1:N0} km">
                                <Binding Path="NajdluzszyEtapKm"/>
                                <Binding Path="NajkrotszyEtapKm"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>


                    <TextBlock Text="NOCLEGI" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBlock Margin="0,2">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🏨 Najdroższy nocleg: {0:N0} PLN    🏨 Najtańszy: {1:N0} PLN">
                                <Binding Path="NoclegiMax"/>
                                <Binding Path="NoclegiMin"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Margin="0,2">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🛏️ Średnia cena za noc: {0:N0} PLN    🛏️ Łącznie nocy: {1}">
                                <Binding Path="NoclegiAvg"/>
                                <Binding Path="LiczbaNocy"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <TextBlock Text="ZWIEDZANIE" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBlock Margin="0,2"
           TextWrapping="Wrap">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🎫 Najdroższe: {0} – {1:N0} PLN">
                                <Binding Path="NajlepiejOcenione"/>
                                <Binding Path="ZwiedzanieMax"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <TextBlock Margin="0,2"
           TextWrapping="Wrap">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🎫 Najtańsze: {0} – {1:N0} PLN">
                                <Binding Path="NajgorzejOcenione"/>
                                <Binding Path="ZwiedzanieMin"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <TextBlock Margin="0,2">
                        <TextBlock.Text>
                            <Binding Path="ZwiedzanieSum" StringFormat="💸 Łączny koszt zwiedzania: {0:N0} PLN"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10" Background="#F0F8FF">
                <StackPanel x:Name="OgolneInfoGrid">

                    <TextBlock FontSize="16" FontWeight="Bold" Text="{Binding Tytul}" />

   
                    <TextBlock Margin="0,2,0,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="🌍 Miejsce: {0}, {1}">
                                <Binding Path="Kraj"/>
                                <Binding Path="Miasto"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>


                    <TextBlock Margin="0,2,0,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="📅 Termin: {0:dd.MM.yyyy} – {1:dd.MM.yyyy}">
                                <Binding Path="DataOd"/>
                                <Binding Path="DataDo"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

   
                    <TextBlock Text="{Binding Opis}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="🚆 DOJAZDY" FontSize="16" FontWeight="Bold" Margin="0,5,0,5"/>
            <ItemsControl x:Name="icDojazdy" ItemsSource="{Binding}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10" Background="#FAFAFA">
                            <StackPanel Orientation="Vertical">

                                <TextBlock FontWeight="Bold"
           FontSize="14"
           TextWrapping="Wrap">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} → {1}">
                                            <Binding Path="start"/>
                                            <Binding Path="cel"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>


                                <TextBlock Margin="0,2,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Transport: {0}, Przewoźnik: {1}">
                                            <Binding Path="transport"/>
                                            <Binding Path="przewoznik"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <TextBlock Margin="0,2,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Nr rejsu: {0}, Nr miejsca: {1}">
                                            <Binding Path="numer_rejsu"/>
                                            <Binding Path="numer_miejsca"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

         
                                <TextBlock Margin="0,2,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Wyjazd: {0:d}, Przyjazd: {1:d}, Cena: {2}">
                                            <Binding Path="data_wyjazdu"/>
                                            <Binding Path="data_przyjazdu"/>
                                            <Binding Path="cena"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

 
                                <TextBlock Text="{Binding uwagi}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>


            <TextBlock Text="🏨 NOCLEGI" FontSize="16" FontWeight="Bold" Margin="0,5,0,5"/>
            <ItemsControl x:Name="icNoclegi" ItemsSource="{Binding}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10" Background="#FFF5F5">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="{Binding nazwa}" FontSize="14"/>
                                <TextBlock Text="{Binding adres}" Margin="0,2,0,0"/>
                                <TextBlock Margin="0,2,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Kategoria: {0}, Ocena: {1}">
                                            <Binding Path="kategoria"/>
                                            <Binding Path="ocena"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="0,2,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Data: {0:d} – {1:d}, Cena: {2}">
                                            <Binding Path="data_od"/>
                                            <Binding Path="data_do"/>
                                            <Binding Path="cena"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding uwagi}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="🎫 ZWIEDZANIE" FontSize="16" FontWeight="Bold" Margin="0,5,0,5"/>
            <ItemsControl x:Name="icZwiedzanie" ItemsSource="{Binding}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10" Background="#F0FFF0">
                            <StackPanel>
                                <TextBlock FontWeight="Bold"
           FontSize="14"
           Text="{Binding nazwa}"
           TextWrapping="Wrap"/>

                                <TextBlock Margin="0,2,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Kategoria: {0}, Data: {1}, Cena: {2}, Ocena: {3}">
                                            <Binding Path="typ"/>
    
                                            <Binding Path="data"/>
                                            <Binding Path="cena"/>
                                            <Binding Path="ocena"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding uwagi}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>



            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Eksportuj PDF" Click="BtnPDF_Click" Width="120" Margin="0,0,10,0"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
